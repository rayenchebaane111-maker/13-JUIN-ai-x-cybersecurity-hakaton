MONGODB_URI=mongodb://mongo:27017/shield
JWT_SECRET=your-secret-key
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://extension.local
JWT_EXPIRES_IN=7d
LLM_ENABLED=true
LLM_API_KEY=your_together_key
LLM_BASE_URL=https://api.together.xyz/v1
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
LLM_TIMEOUT_MS=12000
LLM_WEIGHT=0.3
LLM_ALWAYS_ON=false
LLM_DOMAIN_PROFILE=general phishing defense
LLM_PRIORITY_LABELS=credential_harvest,business_email_compromise,payment_fraud,impersonation
LLM_DECISION_POLICY=Prefer caution for financial/account-access requests with urgency

# Rule tuning profile (comma-separated lowercase terms)
PHISHING_KEYWORDS=verify,account suspended,account locked,password reset,confirm identity,security alert,urgent action,click now,update billing,unusual activity
URGENCY_KEYWORDS=urgent,immediately,act now,asap,final notice,last chance,within 24 hours
FINANCIAL_KEYWORDS=wire transfer,bank account,routing number,swift,credit card,bitcoin,gift card,crypto
URL_SHORTENERS=bit.ly,tinyurl.com,t.co,rb.gy,is.gd,cutt.ly
SUSPICIOUS_TLDS=.tk,.top,.xyz,.click,.work,.gq,.ml
KNOWN_BAD_IPS=185.220.101.42,45.95.147.201,103.15.28.77
KNOWN_BAD_DOMAINS=secure-bankverify.tk,vendor-payments-check.top,hr-alert-check.xyz

# Rule scoring calibration
SCORE_PHISHING_PER_KEYWORD=8
SCORE_URGENCY_PER_KEYWORD=6
SCORE_LINK_PER_SIGNAL=12
SCORE_SENDER_PER_SIGNAL=5
SCORE_FINANCIAL_PER_KEYWORD=5
SCORE_INTEL_PER_MATCH=15

# Threat thresholds
THRESHOLD_LOW_MAX=24
THRESHOLD_MEDIUM_MAX=49
THRESHOLD_HIGH_MAX=74
