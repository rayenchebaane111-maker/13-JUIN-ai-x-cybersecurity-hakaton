{
  "manifest_version": 3,
  "name": "AI Cyber Human Shield",
  "version": "1.0.0",
  "description": "Explainable phishing detection for Gmail and Outlook Web with local-first analysis.",
  "permissions": ["scripting", "storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Cyber Human Shield",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*"
      ],
      "js": ["src/utils/debugger.js", "src/content/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
